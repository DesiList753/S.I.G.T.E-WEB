# Base de datos PostgreSQL (Neon)
# URL con connection pooling via PgBouncer (para queries y migraciones)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# JWT — cambiar por un secreto seguro en producción (mínimo 32 caracteres)
JWT_SECRET="cambia-esto-en-produccion-usa-openssl-rand-hex-32"
JWT_ISSUER="sigte.local"
JWT_AUDIENCE="sigte.app"
